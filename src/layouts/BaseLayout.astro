---
import "../styles/global.css";
import "../styles/grid.css";
import "../styles/animations.css";
import "../styles/ticker.css";
import ParticleCanvas from "../components/ParticleCanvas.astro";
import TopBar from "../components/TopBar.astro";
import { ViewTransitions } from "astro:transitions";
import ScrollToTop from "../components/ScrollToTop.astro";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <ViewTransitions />
    <meta name="description" content="Portfolio de Alexander Ruiz Diaz" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Syne:wght@400;600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <TopBar />
    <ParticleCanvas />
    <script>
      document.addEventListener("mousemove", (e) => {
        document.documentElement.style.setProperty(
          "--mouse-x",
          `${e.clientX}px`,
        );
        document.documentElement.style.setProperty(
          "--mouse-y",
          `${e.clientY}px`,
        );
      });
    </script>

    <div class="app-layout">
      <aside class="panel-left">
        <slot name="left-panel" />
      </aside>

      <main class="panel-right">
        <slot name="right-panel" />
      </main>
    </div>
    <script>
      // Envolvemos el observer en el evento nativo de Astro para SPA routing
      document.addEventListener("astro:page-load", () => {
        const prefersReducedMotion = window.matchMedia(
          "(prefers-reduced-motion: reduce)",
        ).matches;
        if (prefersReducedMotion) {
          // Fallback de seguridad: si no hay animación, forzamos visibilidad
          document
            .querySelectorAll(".section-animate")
            .forEach((el) => el.classList.add("visible"));
          return;
        }

        const observerOptions = {
          root: null,
          rootMargin: "0px",
          threshold: 0.15,
        };

        const observer = new IntersectionObserver((entries, obs) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("visible");
              obs.unobserve(entry.target);
            }
          });
        }, observerOptions);

        setTimeout(() => {
          document.querySelectorAll(".section-animate").forEach((section) => {
            observer.observe(section);
          });
        }, 50);
      });
    </script>

    <style is:global>
      /* ==========================================================
         CRÍTICO: MUTACIÓN ESTRUCTURAL DE EJES (VIEWPORT <= 1024px)
         ========================================================== */
      @media screen and (max-width: 1024px) {
        /* Colapso del contenedor principal a vector unidimensional vertical */
        .app-layout {
          display: flex !important;
          flex-direction: column !important;
          min-height: 100vh !important;
          overflow-x: hidden !important;
        }

        /* Liberación geométrica del panel lateral (Sidebar) */
        .panel-left {
          position: relative !important;
          width: 100% !important;
          height: auto !important;
          min-height: auto !important;
          max-height: none !important;
          border-right: none !important;
          border-bottom: 1px solid rgba(224, 197, 143, 0.2) !important;
          overflow-y: visible !important;
          padding: 3rem 1.5rem 2rem 1.5rem !important;
          display: flex !important;
          flex-direction: column !important;
          align-items: center !important;
          text-align: center !important;
          z-index: 10 !important;
        }

        /* Ajuste de márgenes del panel de contenido principal */
        .panel-right {
          width: 100% !important;
          margin-left: 0 !important;
          padding: 2rem 1.5rem !important;
          overflow-y: visible !important;
        }

        /* Forzado de alineación central para los elementos hijos del panel izquierdo */
        .panel-left > * {
          align-items: center !important;
          text-align: center !important;
          width: 100% !important;
        }
      }
    </style>
    <ScrollToTop />
  </body>
</html>
