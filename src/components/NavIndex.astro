---
// src/components/NavIndex.astro
import { useTranslations } from "../i18n/utils";
import type { TranslationKey } from "../i18n/utils";

const lang = (Astro.params.lang as "es" | "en") || "es";
const t = useTranslations(lang);

const navItems: { id: string; key: TranslationKey }[] = [
  { id: "acerca-de", key: "nav.about" },
  { id: "experiencia", key: "nav.experience" },
  { id: "proyectos", key: "nav.projects" },
  { id: "multimedia", key: "nav.media" },
  { id: "contacto", key: "nav.contact" },
];
---

<nav aria-label="Navegación principal de secciones">
  <ul class="nav-list">
    {
      navItems.map((item) => (
        <li>
          <a href={`#${item.id}`} class="nav-link" data-section={item.id}>
            <span class="nav-indicator" />
            <span class="nav-text">{t(item.key)}</span>
          </a>
        </li>
      ))
    }
  </ul>
</nav>

<style>
  .nav-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    color: var(--color-muted);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    transition: color 300ms ease;
  }

  .nav-indicator {
    display: block;
    width: 0;
    height: 1px;
    background-color: var(--color-gold);
    margin-right: 0;
    transition:
      width 300ms ease,
      margin-right 300ms ease;
  }

  .nav-link:hover .nav-indicator,
  .nav-link.active .nav-indicator {
    width: 20px;
    margin-right: 15px;
  }

  .nav-link:hover .nav-text {
    color: var(--color-gold);
  }

  /* Estado ACTIVO: Color sólido + Luminiscencia áurea */
  .nav-link.active .nav-text {
    color: var(--color-gold);
    text-shadow:
      0 0 12px rgba(224, 197, 143, 0.7),
      0 0 24px rgba(224, 197, 143, 0.4);
  }
</style>

<script>
  document.addEventListener("astro:page-load", () => {
    const links = document.querySelectorAll(".nav-link");
    if (!links.length) return;

    // Compensación de 150px superior para no activar las secciones que están ocultas bajo el TopBar
    const observerOptions = {
      root: null,
      rootMargin: "-150px 0px -60% 0px",
      threshold: 0,
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute("id");
          links.forEach((link) => {
            link.classList.toggle(
              "active",
              link.getAttribute("data-section") === id,
            );
          });
        }
      });
    }, observerOptions);

    setTimeout(() => {
      const sections = document.querySelectorAll(".panel-right section[id]");
      sections.forEach((section) => observer.observe(section));
    }, 100);
  });
</script>
