---
interface Props {
  channelName: string;
  channelUrl: string;
  profileImage: string;
  altText?: string;
}

const {
  channelName,
  channelUrl,
  profileImage,
  altText = channelName,
} = Astro.props;
---

<div class="card">
  <!-- Enlace al canal (parte superior) -->
  <a
    href={channelUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="channel-link"
  >
    <svg class="yt-icon" viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M23.5 6.2a3 3 0 0 0-2.1-2.1C19.5 3.6 12 3.6 12 3.6s-7.5 0-9.4.5A3 3 0 0 0 .5 6.2C0 8.1 0 12 0 12s0 3.9.5 5.8a3 3 0 0 0 2.1 2.1c1.9.5 9.4.5 9.4.5s7.5 0 9.4-.5a3 3 0 0 0 2.1-2.1C24 15.9 24 12 24 12s0-3.9-.5-5.8zM9.7 15.5V8.5l6.3 3.5-6.3 3.5z"
      ></path>
    </svg>
    Ver canal
  </a>

  <!-- Imagen de perfil (parte media) -->
  <div class="profile-wrapper">
    <img src={profileImage} alt={altText} class="profile-image" />
  </div>

  <!-- Nombre del canal (parte inferior) -->
  <p class="channel-name">{channelName}</p>
</div>

<style>
  .card {
    position: relative;
    width: 190px;
    height: 254px;
    background-color: #000;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: center;
    padding: 16px 12px;
    gap: 12px;
    border-radius: 8px;
    cursor: pointer;
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    left: -5px;
    margin: auto;
    width: 200px;
    height: 264px;
    border-radius: 10px;
    /* CRÍTICO: Gradiente armonizado con su color base */
    background: linear-gradient(-45deg, #dcc28e 0%, #f2e3c6 100%);
    z-index: -10;
    pointer-events: none;
    transition: all 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .card::after {
    content: "";
    z-index: -1;
    position: absolute;
    inset: 0;
    /* CRÍTICO: Gradiente armonizado para el resplandor */
    background: linear-gradient(-45deg, #dcc28e 0%, #f2e3c6 100%);
    transform: translate3d(0, 0, 0) scale(0.95);
    filter: blur(20px);
  }

  .card:hover::after {
    filter: blur(30px);
  }

  .card:hover::before {
    transform: rotate(-90deg) scaleX(1.34) scaleY(0.77);
  }

  .channel-link {
    display: flex;
    align-items: center;
    gap: 6px;
    background-color: #dcc28e; /* CRÍTICO: Sincronización de color */
    color: #000;
    text-decoration: none;
    font-size: 12px;
    font-weight: 700;
    padding: 6px 12px;
    border-radius: 20px;
    transition:
      background 0.2s,
      transform 0.2s;
    z-index: 1;
  }

  .channel-link:hover {
    background-color: #fff;
    transform: scale(1.05);
  }

  .yt-icon {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  /* Imagen de perfil central */
  .profile-wrapper {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1;
  }

  .profile-image {
    width: 90px;
    height: 90px;
    border-radius: 50%;
    object-fit: cover;
    border: 3px solid #dcc28e; /* CRÍTICO: Sincronización de color */
    transition:
      transform 0.3s ease,
      border-color 0.3s ease;
  }

  .card:hover .profile-image {
    transform: scale(1.08);
    border-color: #fff;
  }

  /* Nombre del canal inferior */
  .channel-name {
    font-size: 14px;
    font-weight: 700;
    color: #fff;
    text-align: center;
    z-index: 1;
    margin: 0;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.6);
  }
</style>

